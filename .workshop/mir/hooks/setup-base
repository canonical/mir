set -xeu

add-apt-repository --yes --enable-source --update ppa:mir-team/dev
apt-get --yes --no-install-recommends install \
  build-essential \
  cargo \
  ccache \
  clang \
  dmz-cursor-theme \
  fonts-ubuntu \
  glmark2-es2 \
  glmark2-es2-wayland \
  mesa-utils \
  mold \
  ninja-build \
  python3-venv \
  ripgrep \
  xterm \
  yq
apt-get --no-install-recommends build-dep mir

cat <<'EOF' > /etc/profile.d/mir.sh
export PATH="$HOME/build/bin:$PATH"
export CCACHE_SLOPPINESS=include_file_ctime,include_file_mtime,modules,pch_defines,time_macros
EOF
