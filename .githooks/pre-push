#!/bin/bash
# Pre-push hook for Mir project
# Runs ABI symbol checks (only if public API headers were modified) before allowing a push.
# Can be bypassed with: git push --no-verify
#
# Environment variables:
#   MIR_SKIP_SYMBOL_CHECK=true   Skip symbol checks

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Debian symbol checks require dpkg-gensymbols; check once, at the very top.
if command -v dpkg-gensymbols &> /dev/null; then
    dpkg_available=true
else
    dpkg_available=false
fi

# Determine the compare base (the branch's upstream tracking ref).
REMOTE="${1:-origin}"
BRANCH="${2:-$(git rev-parse --abbrev-ref HEAD)}"
TRACKING_BRANCH=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "$REMOTE/$BRANCH")

# Check if any public API headers (include/) were modified relative to the tracking branch.
public_api_modified=false
if git rev-parse --verify "$TRACKING_BRANCH" &> /dev/null; then
    if git diff --name-only "$TRACKING_BRANCH"...HEAD | grep -q '^include/'; then
        public_api_modified=true
    fi
fi

# Paths that the symbol-check targets may regenerate. Used to detect auto-fixes.
SYMBOL_PATHSPECS=('*symbols.map' 'debian/*.symbols')

symbol_files_signature() {
    git diff HEAD -- "${SYMBOL_PATHSPECS[@]}" | git hash-object --stdin
}

if [ "${MIR_SKIP_SYMBOL_CHECK}" = "true" ]; then
    echo -e "${YELLOW}Skipping symbol checks (MIR_SKIP_SYMBOL_CHECK=true)${NC}"
elif [ "$public_api_modified" = false ]; then
    echo -e "${YELLOW}No public API headers modified. Skipping symbol checks.${NC}"
else
    echo -e "${YELLOW}Public API headers modified. Running symbol check before push...${NC}"
    echo

    # Configure CMake if no build directory exists yet.
    if [ ! -d "build" ]; then
        echo -e "${YELLOW}Build directory not found. Configuring CMake...${NC}"
        cmake -B build . || {
            echo -e "${RED}Failed to configure CMake. Bypassing symbol check.${NC}"
            echo -e "${YELLOW}Note: Symbol check will still run in CI. Use 'git push --no-verify' to skip this hook.${NC}"
            exit 0
        }
        echo
    fi

    RET=0
    signature_before=$(symbol_files_signature)

    # Symbol-map checks only diff; when one fails we regenerate the map (the fix),
    # then abort below so the updated map can be reviewed and committed.
    run_map_check() {
        local lib=$1
        echo -e "${YELLOW}Checking ${lib} symbols map...${NC}"
        if ! cmake --build build --target "check-${lib}-symbols-map" -j$(nproc); then
            echo -e "${RED}✗ ${lib} symbols map out of date; regenerating...${NC}"
            cmake --build build --target "generate-${lib}-symbols-map" -j$(nproc) || true
            RET=1
        fi
    }

    run_map_check miral
    run_map_check miroil
    run_map_check mirserver
    run_map_check mircommon

    # Debian symbol checks self-heal: running the target appends any missing
    # symbols to debian/*.symbols. We detect that mutation below and abort.
    if [ "$dpkg_available" = true ]; then
        echo -e "${YELLOW}Checking Debian symbols...${NC}"
        cmake --build build --target regenerate-miral-debian-symbols -j$(nproc) || RET=1
        cmake --build build --target check-miroil-symbols -j$(nproc) || RET=1
    else
        echo -e "${YELLOW}dpkg-gensymbols not found. Skipping Debian symbols checks.${NC}"
    fi

    echo

    signature_after=$(symbol_files_signature)
    tree_modified=false
    if [ "$signature_before" != "$signature_after" ]; then
        tree_modified=true
    fi

    if [ "$RET" -ne 0 ] || [ "$tree_modified" = true ]; then
        if [ "$tree_modified" = true ]; then
            echo -e "${RED}Symbol files were updated to match your changes. Push rejected.${NC}"
            echo
            echo -e "${YELLOW}Review and commit the regenerated symbol files, then push again:${NC}"
            git --no-pager diff --stat -- "${SYMBOL_PATHSPECS[@]}"
        else
            echo -e "${RED}Symbol check failed. Push rejected.${NC}"
        fi
        echo
        echo -e "${YELLOW}Options:${NC}"
        echo "  1. Review/commit the updated symbol files (or fix the issue) and push again"
        echo "  2. Bypass this check: ${YELLOW}git push --no-verify${NC}"
        echo "  3. Skip symbol check: ${YELLOW}MIR_SKIP_SYMBOL_CHECK=true git push${NC}"
        echo
        exit 1
    fi

    echo -e "${GREEN}✓ All symbol checks passed!${NC}"
fi

echo
echo -e "${GREEN}✓ Pre-push checks completed!${NC}"
