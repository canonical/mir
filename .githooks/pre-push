#!/bin/bash
# Pre-push hook for Mir project
# Runs symbol checks (if public API headers were modified) and optionally code review before allowing a push
# Can be bypassed with: git push --no-verify
#
# Environment variables:
#   MIR_CODE_REVIEW=true/false         Enable/disable code review (default: true)
#   MIR_CODE_REVIEW_VERBOSE=true       Show verbose output from code review
#   MIR_SKIP_SYMBOL_CHECK=true         Skip symbol checks

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Check if public API headers were modified
public_api_modified=false
REMOTE="${1:-origin}"
BRANCH="${2:-$(git rev-parse --abbrev-ref HEAD)}"
TRACKING_BRANCH=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "$REMOTE/$BRANCH")

if git rev-parse --verify "$TRACKING_BRANCH" &> /dev/null; then
    # Check if any files in include/ directory (public API headers) were modified
    if git diff --name-only "$TRACKING_BRANCH"...HEAD | grep -q '^include/'; then
        public_api_modified=true
    fi
fi

# Check if symbol check is disabled
if [ "${MIR_SKIP_SYMBOL_CHECK}" = "true" ]; then
    echo -e "${YELLOW}Skipping symbol checks (MIR_SKIP_SYMBOL_CHECK=true)${NC}"
elif [ "$public_api_modified" = false ]; then
    echo -e "${YELLOW}No public API headers modified. Skipping symbol checks.${NC}"
else
    echo -e "${YELLOW}Public API headers modified. Running symbol check before push...${NC}"
    echo

    # Check if build directory exists
    if [ ! -d "build" ]; then
        echo -e "${YELLOW}Build directory not found. Configuring CMake...${NC}"
        cmake -B build . || {
            echo -e "${RED}Failed to configure CMake. Bypassing symbol check.${NC}"
            echo -e "${YELLOW}Note: Symbol check will still run in CI. Use 'git push --no-verify' to skip this hook.${NC}"
            exit 0
        }
        echo
    fi

    # Run symbol map checks
    echo -e "${YELLOW}Checking symbol maps...${NC}"
    RET=0

    cmake --build build --target check-miral-symbols-map 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ miral symbols map check failed${NC}"
    }

    cmake --build build --target check-miroil-symbols-map 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ miroil symbols map check failed${NC}"
    }

    cmake --build build --target check-mirserver-symbols-map 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ mirserver symbols map check failed${NC}"
    }

    cmake --build build --target check-mircommon-symbols-map 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ mircommon symbols map check failed${NC}"
    }

    # Run Debian symbols checks (only available when dpkg-gensymbols is present)
    echo -e "${YELLOW}Checking Debian symbols...${NC}"

    cmake --build build --target regenerate-miral-debian-symbols 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ miral Debian symbols check failed${NC}"
    }

    cmake --build build --target check-miroil-symbols 2>/dev/null || {
        RET=$?
        echo -e "${RED}✗ miroil Debian symbols check failed${NC}"
    }

    echo

    if [ $RET -ne 0 ]; then
        echo -e "${RED}Symbol check failed. Push rejected.${NC}"
        echo
        echo -e "${YELLOW}Options:${NC}"
        echo "  1. Fix the symbol issues and try again"
        echo "  2. Bypass this check: ${YELLOW}git push --no-verify${NC}"
        echo "  3. Skip symbol check: ${YELLOW}MIR_SKIP_SYMBOL_CHECK=true git push${NC}"
        echo
        echo -e "${YELLOW}For detailed output, run:${NC}"
        echo "  cmake --build build --target check-miral-symbols-map"
        echo "  cmake --build build --target check-miroil-symbols-map"
        echo "  cmake --build build --target check-mirserver-symbols-map"
        echo "  cmake --build build --target check-mircommon-symbols-map"
        echo "  cmake --build build --target regenerate-miral-debian-symbols"
        echo "  cmake --build build --target check-miroil-symbols"
        echo
        exit 1
    fi

    echo -e "${GREEN}✓ All symbol checks passed!${NC}"
fi

echo

# Run code review if enabled
if command -v copilot &> /dev/null && [ "${MIR_CODE_REVIEW:-true}" = "true" ]; then

    # Verify the tracking branch exists
    if git rev-parse --verify "$TRACKING_BRANCH" &> /dev/null; then
        echo -e "${YELLOW}Running code review...${NC}"
        echo

        DIFF=$(git diff "$TRACKING_BRANCH"...HEAD)

        if [ -z "$DIFF" ]; then
            echo -e "${YELLOW}No changes to review (empty diff).${NC}"
        else
            FULL_PROMPT="You are an expert code reviewer for the Mir project. Review the following diff and provide:

1. **Critical Issues**: Security, memory safety, ABI stability concerns, or bugs
2. **Code Quality**: Style guide compliance (per .github/copilot-instructions.md), naming conventions, readability
3. **Architecture**: Design patterns, component separation, interface design
4. **Testing**: Suggestions for test coverage

Be concise but thorough. Focus on actionable feedback. Reference the Mir coding standards when applicable.

Format your response with clear sections and use markdown.

DIFF:
$DIFF"

            if ! copilot --model claude-haiku-4.5 -p "$FULL_PROMPT"; then
                echo -e "${RED}Error: Failed to get code review${NC}"
                exit 1
            fi

            echo
            read -p "Continue with push? (y/n) " -n 1 -r
            echo
            if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                echo -e "${YELLOW}Push cancelled.${NC}"
                exit 1
            fi
        fi
    fi
fi

echo -e "${GREEN}✓ Pre-push checks completed!${NC}"
