#!/bin/bash
# Code review hook for Mir project
# Diffs HEAD against remote branch and sends to Claude Haiku 4.5 for code review
# Can be disabled with: git push --no-verify or --no-git-hooks
# Dry-run: MIR_SKIP_CODE_REVIEW_DRY_RUN=true .husky/code-review

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Configuration
SKIP_CODE_REVIEW="${MIR_SKIP_CODE_REVIEW:-false}"
VERBOSE="${MIR_SKIP_CODE_REVIEW_VERBOSE:-false}"
DRY_RUN="${MIR_SKIP_CODE_REVIEW_DRY_RUN:-false}"
REMOTE="${1:-origin}"
BRANCH="${2:-$(git rev-parse --abbrev-ref HEAD)}"

# Check if code review is disabled
if [ "$SKIP_CODE_REVIEW" = "true" ]; then
    if [ "$VERBOSE" = "true" ]; then
        echo -e "${YELLOW}Code review skipped (MIR_SKIP_CODE_REVIEW=true)${NC}"
    fi
    exit 0
fi

# Check if copilot is available (skip in dry-run)
if [ "$DRY_RUN" != "true" ] && ! command -v copilot &> /dev/null; then
    echo -e "${YELLOW}Warning: copilot not found. Skipping code review.${NC}"
    exit 0
fi

# Determine the remote tracking branch
TRACKING_BRANCH=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "$REMOTE/$BRANCH")

# Verify the tracking branch exists
if ! git rev-parse --verify "$TRACKING_BRANCH" &> /dev/null; then
    echo -e "${YELLOW}Tracking branch '$TRACKING_BRANCH' not found. Skipping code review.${NC}"
    exit 0
fi

echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
if [ "$DRY_RUN" = "true" ]; then
    echo -e "${BLUE}  Mir Code Review - DRY RUN${NC}"
else
    echo -e "${BLUE}  Mir Code Review - Claude Haiku 4.5${NC}"
fi
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo

# Get the diff
DIFF=$(git diff "$TRACKING_BRANCH"...HEAD)

if [ -z "$DIFF" ]; then
    echo -e "${YELLOW}No changes to review (empty diff).${NC}"
    exit 0
fi

echo -e "${YELLOW}Reviewing changes against: $TRACKING_BRANCH${NC}"
echo -e "${YELLOW}Current branch: $BRANCH${NC}"
echo

# Build the full prompt with the diff included
FULL_PROMPT="You are an expert code reviewer for the Mir project. Review the following diff and provide:

1. **Critical Issues**: Security, memory safety, ABI stability concerns, or bugs
2. **Code Quality**: Style guide compliance (per .github/copilot-instructions.md), naming conventions, readability
3. **Architecture**: Design patterns, component separation, interface design
4. **Testing**: Suggestions for test coverage

Be concise but thorough. Focus on actionable feedback. Reference the Mir coding standards when applicable.

Format your response with clear sections and use markdown.

DIFF:
$DIFF"

if [ "$DRY_RUN" = "true" ]; then
    echo "Diff size: $(echo "$DIFF" | wc -l) lines"
    echo "Tracking branch: $TRACKING_BRANCH"
    echo
    echo -e "${YELLOW}Testing copilot...${NC}"
    echo

    # Check if copilot is installed
    if ! command -v copilot &> /dev/null; then
        echo -e "${RED}✗ copilot not found${NC}"
        echo
        exit 1
    else
        echo -e "${GREEN}✓ copilot installed${NC}"
    fi

    # Try a test call to verify credentials
    echo -e "${YELLOW}Testing API credentials...${NC}"
    echo "Running: copilot --model claude-haiku-4.5 -p \"respond with: SUCCESS\""
    echo

    TEMP_OUTPUT=$(mktemp)
    trap "rm -f $TEMP_OUTPUT" EXIT

    if copilot --model claude-haiku-4.5 -p "respond with: SUCCESS" > "$TEMP_OUTPUT" 2>&1; then
        TEST_EXIT=0
    else
        TEST_EXIT=$?
    fi

    TEST_RESULT=$(cat "$TEMP_OUTPUT")

    echo "Exit code: $TEST_EXIT"
    echo "Output length: $(echo "$TEST_RESULT" | wc -c) bytes"
    echo

    if [ $TEST_EXIT -eq 0 ]; then
        echo -e "${GREEN}✓ API connection successful${NC}"
        echo
        echo "Response:"
        echo "---"
        echo "$TEST_RESULT"
        echo "---"
    else
        echo -e "${RED}✗ API connection failed (exit code: $TEST_EXIT)${NC}"
        echo
        echo "Error output:"
        echo "---"
        echo "$TEST_RESULT"
        echo "---"
        echo
        echo -e "${YELLOW}Troubleshooting:${NC}"
        echo "1. Check authentication: copilot auth status"
        echo "2. Re-authenticate if needed: copilot auth login"
        echo "3. Check available models: copilot --help"
        exit 1
    fi
else
    if [ "$VERBOSE" = "true" ]; then
        echo -e "${BLUE}Sending diff to Claude Haiku 4.5 for review...${NC}"
    fi

    if ! copilot --model claude-haiku-4.5 -p "$FULL_PROMPT"; then
        echo -e "${RED}Error: Failed to get code review${NC}"
        echo -e "${YELLOW}Make sure you have API credentials configured${NC}"
        exit 1
    fi
fi

echo
echo -e "${BLUE}═══════════════════════════════════════════════════════════${NC}"
echo

# Prompt user to continue (skip in dry-run)
if [ "$DRY_RUN" != "true" ]; then
    read -p "Continue with push? (y/n) " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        echo -e "${YELLOW}Push cancelled.${NC}"
        exit 1
    fi
else
    echo -e "${BLUE}Dry-run complete.${NC}"
fi

exit 0
